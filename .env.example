# LLM Provider Configuration
# Choose: claude, openai, deepseek, kimi, minimax
LLM_PROVIDER=deepseek

# Anthropic Claude API
ANTHROPIC_API_KEY=your_claude_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI GPT API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# DeepSeek API
DEEPSEEK_API_KEY=your_kimi_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Kimi API (Moonshot)
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# Minimax API
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_group_id_here
MINIMAX_MODEL=abab6.5-chat

# Agent Configuration
AGENT_NAME=MyAgent
AGENT_MAX_MEMORY_TURNS=20
AGENT_TEMPERATURE=0.7

# Security
ALLOWED_COMMANDS=dir,ls,cat,type,echo,python,pip,git
MAX_COMMAND_TIMEOUT=30

# Database
DATABASE_PATH=./data/sqlite/agent.db
VECTOR_DB_PATH=./data/chroma

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log
